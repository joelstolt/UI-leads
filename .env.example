# SerpAPI — krävs för scrape.js
# Skapa konto på: https://serpapi.com
# Gratis: 100 searches/månad. Betalt: från $50/mån för 5 000 searches.
SERPAPI_KEY=din-nyckel-här

# PageSpeed Insights API — valfritt (funkar utan men med rate limits)
# Hämta på: https://console.cloud.google.com
# Aktivera "PageSpeed Insights API" under APIs & Services
PAGESPEED_API_KEY=din-nyckel-här

# Anthropic API — krävs för enrich-usp.js (USP-extraktion) och outreach-gen.js (kall-outreach via Claude Haiku)
# Hämta på: https://console.anthropic.com
ANTHROPIC_API_KEY=your-key-here

# OpenPageRank — valfritt, för enrich-domainrank.js (Domain Rating 0-10, gratis 1000/dag)
# Skaffa: https://www.domcop.com/openpagerank/auth/signup
OPENPAGERANK_API_KEY=

# Meta Ad Library — valfritt, för enrich-ads.js (kollar om bolaget kör Meta-ads)
# Skaffa: https://developers.facebook.com/tools/explorer/ → välj din app → permission "ads_read"
# Långlivad token: använd System User i Business Manager
META_ACCESS_TOKEN=

# CRM webhook — krävs för crm-sync.js
CRM_WEBHOOK_URL=https://ditt-crm.vercel.app/api/webhook/leads/TOKEN
CRM_WEBHOOK_TOKEN=din-webhook-token
CRM_DEFAULT_PROJECT_ID=

# Audit-bas-URL — valfritt, används av outreach-gen.js för att lägga personlig audit-länk i mejlet
# Default: http://localhost:3001 (lämpligt för dev). Sätt till din publika URL i prod.
AUDIT_BASE_URL=http://localhost:3001
